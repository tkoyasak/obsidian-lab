{
  "schemaVersion": "0.1.0",
  "name": "Default",
  "behavior": "create",
  "noteContentFormat": "<%*\n   await tp.user.unique_note(tp)\n-%>\n\n![(embed)]({{url}})\n\n## Content\n\n{{content}}\n",
  "properties": [
    {
      "name": "id",
      "value": "",
      "type": "text"
    },
    {
      "name": "created",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "modified",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "title",
      "value": "",
      "type": "text"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "author",
      "value": "{{author}}",
      "type": "multitext"
    },
    {
      "name": "image",
      "value": "{{selector:img[alt=\"画像\"]?src|first}}",
      "type": "text"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "text"
    },
    {
      "name": "categories",
      "value": "[[clippings]]",
      "type": "multitext"
    },
    {
      "name": "tags",
      "value": "",
      "type": "multitext"
    }
  ],
  "triggers": [],
  "noteNameFormat": "{{title}}",
  "path": "Clippings"
}
