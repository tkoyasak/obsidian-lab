{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "References add an optional `url` field. Nullable for cases where the source is offline / handwritten / oral.",
  "title": "Reference note frontmatter",
  "type": "object",
  "properties": {
    "created": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "content_id": {
      "$comment": "AT Protocol TID: 13 chars, base32-sortable, high bit 0. See <https://atproto.com/specs/tid>.",
      "type": "string",
      "pattern": "^[234567abcdefghij][234567abcdefghijklmnopqrstuvwxyz]{12}$"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "public",
        "unlisted"
      ]
    },
    "thumbnail": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri-reference"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "categories": {
      "$comment": "Categories are wiki links to capitalized category notes, e.g. [[Book]].",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\[\\[[0-9A-Z]([0-9a-zA-Z -]*[0-9a-zA-Z])?\\]\\]$"
      },
      "uniqueItems": true
    },
    "tags": {
      "$comment": "Tags are lowercase/hyphenated, not starting or ending with a hyphen.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-z]([0-9a-z-]*[0-9a-z])?$"
      },
      "uniqueItems": true
    },
    "url": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri"
    }
  },
  "additionalProperties": true,
  "required": [
    "created",
    "modified",
    "content_id",
    "visibility",
    "categories",
    "tags"
  ],
  "allOf": [
    {
      "$comment": "References categorized as [[Book]] carry bibliographic metadata.",
      "if": {
        "properties": {
          "categories": {
            "contains": {
              "const": "[[Book]]"
            }
          }
        },
        "required": [
          "categories"
        ]
      },
      "then": {
        "properties": {
          "isbn": {
            "$comment": "ISBN-13: 13 digits, prefix 978 or 979.",
            "type": [
              "string",
              "null"
            ],
            "pattern": "^97[89][0-9]{10}$"
          },
          "ndl_url": {
            "type": [
              "string",
              "null"
            ],
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "translaters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "publisher": {
            "type": [
              "string",
              "null"
            ]
          },
          "published": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "language": {
            "type": [
              "string",
              "null"
            ]
          },
          "ndc10": {
            "type": [
              "string",
              "null"
            ]
          },
          "label": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "required": [
          "title"
        ]
      }
    }
  ]
}
