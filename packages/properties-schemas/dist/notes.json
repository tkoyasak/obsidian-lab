{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Note frontmatter",
  "type": "object",
  "properties": {
    "created": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "content_id": {
      "$comment": "AT Protocol TID: 13 chars, base32-sortable, high bit 0. See <https://atproto.com/specs/tid>.",
      "type": "string",
      "pattern": "^[234567abcdefghij][234567abcdefghijklmnopqrstuvwxyz]{12}$"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "public",
        "unlisted"
      ]
    },
    "thumbnail": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri-reference"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "categories": {
      "$comment": "Categories are wiki links to capitalized category notes, e.g. [[Book]].",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\[\\[[0-9A-Z]([0-9a-zA-Z -]*[0-9a-zA-Z])?\\]\\]$"
      },
      "uniqueItems": true
    },
    "tags": {
      "$comment": "Tags are lowercase/hyphenated, not starting or ending with a hyphen.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-z]([0-9a-z-]*[0-9a-z])?$"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true,
  "required": [
    "created",
    "modified",
    "content_id",
    "visibility",
    "categories",
    "tags"
  ],
  "allOf": [
    {
      "$comment": "Notes categorized as [[Task]] follow the TaskMD format. See `vault/Notes/How I manage tasks.md`.",
      "if": {
        "properties": {
          "categories": {
            "contains": {
              "const": "[[Task]]"
            }
          }
        },
        "required": [
          "categories"
        ]
      },
      "then": {
        "properties": {
          "project": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "Inbox",
              "Icebox",
              "Planned",
              "In Progress",
              "On Hold",
              "Done",
              "Cancelled"
            ]
          },
          "review": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "due": {
            "type": [
              "string",
              "null"
            ],
            "format": "date"
          },
          "contexts": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "waiting_for": {
            "type": [
              "string",
              "null"
            ]
          },
          "estimate": {
            "type": [
              "string",
              "null"
            ]
          },
          "priority": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": [
          "status",
          "priority"
        ],
        "allOf": [
          {
            "$comment": "`review` is required for `Planned` and `On Hold`.",
            "if": {
              "properties": {
                "status": {
                  "enum": [
                    "Planned",
                    "On Hold"
                  ]
                }
              },
              "required": [
                "status"
              ]
            },
            "then": {
              "properties": {
                "review": {
                  "type": "string",
                  "format": "date"
                }
              },
              "required": [
                "review"
              ]
            }
          }
        ]
      }
    }
  ]
}
