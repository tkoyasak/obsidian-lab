{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Clippings/ is shared by Web Clipper clips ([[Clippings]]) and reading highlights ([[Highlight]]).",
  "title": "Clipping frontmatter",
  "type": "object",
  "properties": {
    "created": {
      "type": "string",
      "format": "date"
    },
    "modified": {
      "type": "string",
      "format": "date"
    },
    "content_id": {
      "$comment": "AT Protocol TID: 13 chars, base32-sortable, high bit 0. See <https://atproto.com/specs/tid>.",
      "type": "string",
      "pattern": "^[234567abcdefghij][234567abcdefghijklmnopqrstuvwxyz]{12}$"
    },
    "visibility": {
      "type": "string",
      "enum": [
        "private",
        "public",
        "unlisted"
      ]
    },
    "thumbnail": {
      "type": [
        "string",
        "null"
      ],
      "format": "uri-reference"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "categories": {
      "$comment": "Categories are wiki links to capitalized category notes, e.g. [[Book]].",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^\\[\\[[0-9A-Z]([0-9a-zA-Z -]*[0-9a-zA-Z])?\\]\\]$"
      },
      "uniqueItems": true
    },
    "tags": {
      "$comment": "Tags are lowercase/hyphenated, not starting or ending with a hyphen.",
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[0-9a-z]([0-9a-z-]*[0-9a-z])?$"
      },
      "uniqueItems": true
    }
  },
  "additionalProperties": true,
  "required": [
    "created",
    "modified",
    "content_id",
    "visibility",
    "thumbnail",
    "description",
    "categories",
    "tags"
  ],
  "allOf": [
    {
      "$comment": "Clips made by the Web Clipper. Site templates may add their own fields (allowed via additionalProperties).",
      "if": {
        "properties": {
          "categories": {
            "contains": {
              "const": "[[Clippings]]"
            }
          }
        },
        "required": [
          "categories"
        ]
      },
      "then": {
        "properties": {
          "url": {
            "type": "string",
            "format": "uri"
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "uniqueItems": true
          },
          "published": {
            "type": [
              "string",
              "null"
            ],
            "format": "date-time"
          }
        },
        "required": [
          "url",
          "title",
          "authors",
          "published"
        ]
      }
    },
    {
      "$comment": "Notes categorized as [[Highlight]] cite a page of a [[Book]]. See `vault/Templates/Highlight Template.md`.",
      "if": {
        "properties": {
          "categories": {
            "contains": {
              "const": "[[Highlight]]"
            }
          }
        },
        "required": [
          "categories"
        ]
      },
      "then": {
        "properties": {
          "book": {
            "$comment": "Wiki link to the [[Book]] being highlighted.",
            "type": "string",
            "pattern": "^\\[\\[.+\\]\\]$"
          },
          "page": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          }
        },
        "required": [
          "book",
          "page"
        ]
      }
    }
  ]
}
