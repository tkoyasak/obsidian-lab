module vault.jsonschema.generate

import "@json_schema/JsonSchema.pkl"

local draft202012: String = "https://json-schema.org/draft/2020-12/schema"

local dateString: JsonSchema.Schema = new {
  type = "string"
  format = "date"
}

local tidString: JsonSchema.Schema = new {
  $comment =
    "AT Protocol TID: 13 chars, base32-sortable, high bit 0. See <https://atproto.com/specs/tid>."
  type = "string"
  pattern = #"^[234567abcdefghij][234567abcdefghijklmnopqrstuvwxyz]{12}$"#
}

local nullableString: JsonSchema.Schema = new {
  type = new Listing<JsonSchema.JsonSchemaTypeName> { "string"; "null" }
}

local nullableDate: JsonSchema.Schema = new {
  type = new Listing<JsonSchema.JsonSchemaTypeName> { "string"; "null" }
  format = "date"
}

local tagList: JsonSchema.Schema = new {
  $comment = "Tags are lowercase/hyphenated, not starting or ending with a hyphen."
  type = "array"
  items = new {
    type = "string"
    pattern = #"^[0-9a-z]([0-9a-z-]*[0-9a-z])?$"#
  }
  uniqueItems = true
}

local categoryList: JsonSchema.Schema = new {
  $comment = "Categories are wiki links to capitalized category notes, e.g. [[Book]]."
  type = "array"
  items = new {
    type = "string"
    pattern = #"^\[\[[0-9A-Z]([0-9a-zA-Z -]*[0-9a-zA-Z])?\]\]$"#
  }
  uniqueItems = true
}

local base: JsonSchema = new {
  $schema = draft202012
  title = "Vault frontmatter — common base"
  type = "object"
  additionalProperties = true
  required {
    "created"
    "modified"
    "content_id"
    "visibility"
    "thumbnail"
    "description"
    "categories"
    "tags"
  }
  properties {
    ["created"] = dateString
    ["modified"] = dateString
    ["content_id"] = tidString
    ["visibility"] {
      type = "string"
      enum { "private"; "public"; "unlisted" }
    }
    ["thumbnail"] {
      type = new Listing<JsonSchema.JsonSchemaTypeName> { "string"; "null" }
      format = "uri-reference"
    }
    ["description"] = nullableString
    ["categories"] = categoryList
    ["tags"] = tagList
  }
}

local taskConditional: JsonSchema.Schema = new {
  $comment =
    "Notes categorized as [[Task]] follow the TaskMD format. See `vault/Notes/How I manage tasks.md`."
  `if` {
    required { "categories" }
    properties {
      ["categories"] {
        contains { `const` = "[[Task]]" }
      }
    }
  }
  then {
    required {
      "project"
      "status"
      "started"
      "done"
      "review"
      "due"
      "recurrence"
      "contexts"
      "waiting_for"
      "estimate"
      "priority"
    }
    properties {
      ["project"] = nullableString
      ["status"] {
        type = "string"
        enum {
          "Inbox"
          "Icebox"
          "Planned"
          "In Progress"
          "On Hold"
          "Done"
          "Cancelled"
        }
      }
      ["started"] = nullableDate
      ["done"] = nullableDate
      ["review"] = nullableDate
      ["due"] = nullableDate
      ["recurrence"] {
        $comment =
          "Recurrence cycle: `Daily` or capitalized weekday names. Multiple allowed (e.g. [Monday, Thursday])."
        type = "array"
        items {
          type = "string"
          enum {
            "Daily"
            "Sunday"
            "Monday"
            "Tuesday"
            "Wednesday"
            "Thursday"
            "Friday"
            "Saturday"
          }
        }
        uniqueItems = true
      }
      ["contexts"] {
        type = "array"
        items {
          type = "string"
        }
        uniqueItems = true
      }
      ["waiting_for"] = nullableString
      ["estimate"] = nullableString
      ["priority"] {
        type = "integer"
        minimum = 0
      }
    }
    allOf {
      new {
        $comment = "`review` is required for `Planned` and `On Hold`."
        `if` {
          required { "status" }
          properties {
            ["status"] {
              enum { "Planned"; "On Hold" }
            }
          }
        }
        then {
          required { "review" }
          properties {
            ["review"] = dateString
          }
        }
      }
    }
  }
}

local readingConditional: JsonSchema.Schema = new {
  $comment =
    "Notes categorized as [[Reading]] track a book being read; they must also be [[Task]]. See `vault/Templates/Reading Template.md`."
  `if` {
    required { "categories" }
    properties {
      ["categories"] {
        contains { `const` = "[[Reading]]" }
      }
    }
  }
  then {
    required { "categories"; "book"; "rating" }
    properties {
      ["categories"] {
        $comment = "[[Reading]] implies [[Task]] (reuses the task machinery)."
        contains { `const` = "[[Task]]" }
      }
      ["book"] {
        $comment =
          "Wiki link to the bibliographic [[Book]] note in References/. Required, non-null."
        type = "string"
        pattern = #"^\[\[.+\]\]$"#
      }
      ["rating"] {
        $comment = "Loose 1-5 indicator; null until rated. No fixed anchor definitions."
        type = new Listing<JsonSchema.JsonSchemaTypeName> { "integer"; "null" }
        minimum = 1
        maximum = 5
      }
    }
  }
}

local notes: JsonSchema = (base) {
  title = "Note frontmatter"
  allOf {
    taskConditional
    readingConditional
  }
}

local daily: JsonSchema = (base) {
  title = "Daily note frontmatter"
  $comment = "Daily notes use the date itself as content_id (e.g. 2026-05-20)."
  properties {
    ["content_id"] = dateString
  }
}

local bookConditional: JsonSchema.Schema = new {
  $comment = "References categorized as [[Book]] carry bibliographic metadata."
  `if` {
    required { "categories" }
    properties {
      ["categories"] {
        contains { `const` = "[[Book]]" }
      }
    }
  }
  then {
    required {
      "isbn"
      "ndl_url"
      "title"
      "authors"
      "translaters"
      "publisher"
      "published"
      "language"
      "ndc10"
    }
    properties {
      ["isbn"] {
        $comment = "ISBN-13: 13 digits, prefix 978 or 979."
        type = new Listing<JsonSchema.JsonSchemaTypeName> { "string"; "null" }
        pattern = #"^97[89][0-9]{10}$"#
      }
      ["ndl_url"] {
        type = new Listing<JsonSchema.JsonSchemaTypeName> { "string"; "null" }
        format = "uri"
      }
      ["title"] {
        type = "string"
      }
      ["authors"] {
        type = "array"
        items {
          type = "string"
        }
      }
      ["translaters"] {
        type = "array"
        items {
          type = "string"
        }
      }
      ["publisher"] = nullableString
      ["published"] = nullableDate
      ["language"] = nullableString
      ["ndc10"] = nullableString
    }
  }
}

local references: JsonSchema = (base) {
  title = "Reference note frontmatter"
  $comment =
    "References add a `url` field. Required key; nullable value for cases where the source is offline / handwritten / oral."
  required { "url" }
  properties {
    ["url"] {
      type = new Listing<JsonSchema.JsonSchemaTypeName> { "string"; "null" }
      format = "uri"
    }
  }
  allOf {
    bookConditional
  }
}

local jsonRenderer = (JsonSchema.output.renderer) as JsonRenderer

output {
  files {
    ["daily.json"] { value = daily; renderer = jsonRenderer }
    ["notes.json"] { value = notes; renderer = jsonRenderer }
    ["references.json"] { value = references; renderer = jsonRenderer }
  }
}
