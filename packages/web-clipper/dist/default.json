{
  "schemaVersion": "0.1.0",
  "name": "Default",
  "behavior": "create",
  "noteContentFormat": "\n![(embed)]({{url}})\n\n{{content}}\n",
  "properties": [
    {
      "name": "created",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "modified",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "content_id",
      "value": "<% tp.user.tid() %>",
      "type": "text"
    },
    {
      "name": "visibility",
      "value": "private",
      "type": "text"
    },
    {
      "name": "thumbnail",
      "value": "{{image}}",
      "type": "text"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "categories",
      "value": "[[Clippings]]",
      "type": "multitext"
    },
    {
      "name": "tags",
      "value": "",
      "type": "multitext"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "authors",
      "value": "{{author}}",
      "type": "multitext"
    },
    {
      "name": "published",
      "value": "{{published}}",
      "type": "datetime"
    }
  ],
  "triggers": [],
  "noteNameFormat": "{{title}}",
  "path": "Clippings"
}
