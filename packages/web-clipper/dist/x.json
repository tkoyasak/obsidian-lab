{
  "schemaVersion": "0.1.0",
  "name": "X (Twitter) Post",
  "behavior": "create",
  "noteContentFormat": "\n![(embed)]({{url}})\n\n## Content\n\n{{content}}\n",
  "properties": [
    {
      "name": "created",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "modified",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "content_id",
      "value": "<% tp.user.tid() %>",
      "type": "text"
    },
    {
      "name": "visibility",
      "value": "private",
      "type": "text"
    },
    {
      "name": "thumbnail",
      "value": "{{selector:img[alt=\"画像\"]?src|first}}",
      "type": "text"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "categories",
      "value": "[[Clippings]], [[X (Twitter) Posts]]",
      "type": "multitext"
    },
    {
      "name": "tags",
      "value": "",
      "type": "multitext"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "authors",
      "value": "{{selector:div[data-testid=\"User-Name\"] span|first}}",
      "type": "multitext"
    },
    {
      "name": "published",
      "value": "{{published|date}}",
      "type": "datetime"
    },
    {
      "name": "handle",
      "value": "{{url|split:\"/\"|slice:3,-2}}",
      "type": "text"
    }
  ],
  "triggers": [
    "/^https:\\/\\/x\\.com\\/[A-Za-z0-9_]+\\/status\\/\\d+$/"
  ],
  "noteNameFormat": "{{title}} - {{published|date:\"YYYY-MM-DD\"}}",
  "path": "Clippings"
}
