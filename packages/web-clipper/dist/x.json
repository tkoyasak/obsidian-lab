{
  "schemaVersion": "0.1.0",
  "name": "X (Twitter) Post",
  "behavior": "create",
  "noteContentFormat": "\n![Post on X]({{url}})\n\n{{selector:article[tabindex=\"-1\"] div[data-testid=\"tweetText\"]|first}}\n\n{{selector:article[tabindex=\"-1\"] a[href^=\"https://t.co/\"]?href|unique|join:\"\\n\"}}\n",
  "properties": [
    {
      "name": "created",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "modified",
      "value": "{{date|date:\"YYYY-MM-DD\"}}",
      "type": "date"
    },
    {
      "name": "content_id",
      "value": "<% tp.user.tid() %>",
      "type": "text"
    },
    {
      "name": "visibility",
      "value": "private",
      "type": "text"
    },
    {
      "name": "thumbnail",
      "value": "{{selector:article[tabindex=\"-1\"] img[alt=\"画像\"]?src|first}}",
      "type": "text"
    },
    {
      "name": "description",
      "value": "{{description}}",
      "type": "text"
    },
    {
      "name": "categories",
      "value": "[[Clippings]]",
      "type": "multitext"
    },
    {
      "name": "tags",
      "value": "",
      "type": "multitext"
    },
    {
      "name": "url",
      "value": "{{url}}",
      "type": "text"
    },
    {
      "name": "title",
      "value": "{{title}}",
      "type": "text"
    },
    {
      "name": "authors",
      "value": "{{selector:article[tabindex=\"-1\"] div[data-testid=\"User-Name\"] span|first}}",
      "type": "multitext"
    },
    {
      "name": "published",
      "value": "{{selector:article[tabindex=\"-1\"] time?datetime|first}}",
      "type": "datetime"
    },
    {
      "name": "handle",
      "value": "{{url|split:\"/\"|slice:3,-2}}",
      "type": "text"
    }
  ],
  "triggers": [
    "/^https:\\/\\/x\\.com\\/[A-Za-z0-9_]+\\/status\\/\\d+$/"
  ],
  "noteNameFormat": "{{selector:article[tabindex=\"-1\"] div[data-testid=\"tweetText\"]|first|slice:0,100}} - @{{url|split:\"/\"|slice:3,-2}} {{published|date:\"YYYY-MM-DD\"}}",
  "path": "Clippings"
}
