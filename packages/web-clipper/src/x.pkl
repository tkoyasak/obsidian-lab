amends "default.pkl"

import "../props.pkl"

name = "X (Twitter) Post"

noteContentFormat =
  """

  ![(embed)]({{url}})

  ## Content

  {{content}}

  """

properties =
  (props.common) {
    ["thumbnail"] {
      value = "{{selector:img[alt=\"画像\"]?src|first}}"
    }
    ["categories"] {
      value = "[[Clippings]], [[X (Twitter) Posts]]"
    }
    ["published"] {
      value = "{{published|date}}"
    }
    ["authors"] {
      value = "{{selector:div[data-testid=\"User-Name\"] span|first}}"
    }
    ["handle"] {
      name = "handle"
      value = "{{url|split:\"/\"|slice:3,-2}}"
      type = "text"
    }
  }
    .toMap()
    .values

triggers = List(#"/^https:\/\/x\.com\/[A-Za-z0-9_]+\/status\/\d+$/"#)

noteNameFormat = "{{title}} - {{published|date:\"YYYY-MM-DD\"}}"
