amends "default.pkl"

import "../props.pkl"

name = "X (Twitter) Post"

noteContentFormat =
  """

  ![Post on X]({{url}})

  {{selector:article[tabindex="-1"] div[data-testid="tweetText"]|first}}

  {{selector:article[tabindex="-1"] a[href^="https://t.co/"]?href|unique|join:"\\n"}}

  """

properties =
  (props.common) {
    ["thumbnail"] {
      value = "{{selector:article[tabindex=\"-1\"] img[alt=\"画像\"]?src|first}}"
    }
    ["authors"] {
      value = "{{selector:article[tabindex=\"-1\"] div[data-testid=\"User-Name\"] span|first}}"
    }
    ["published"] {
      value = "{{selector:article[tabindex=\"-1\"] time?datetime|first}}"
    }
    ["handle"] {
      name = "handle"
      value = "{{url|split:\"/\"|slice:3,-2}}"
      type = "text"
    }
  }
    .toMap()
    .values

triggers = List(#"/^https:\/\/x\.com\/[A-Za-z0-9_]+\/status\/\d+$/"#)

noteNameFormat =
  #"{{selector:article[tabindex="-1"] div[data-testid="tweetText"]|first|slice:0,100}} - @{{url|split:"/"|slice:3,-2}} {{published|date:"YYYY-MM-DD"}}"#
