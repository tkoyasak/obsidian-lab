amends "@obsidian.webClipper/Template.pkl"

name = "Default"

behavior = "create"

noteContentFormat =
  """
  <%*
     await tp.user.unique_note(tp)
  -%>

  ![(embed)]({{url}})

  ## Content

  {{content}}

  """

properties =
  List(
    new Property {
      name = "id"
      value = ""
      type = "text"
    },
    new Property {
      name = "created"
      value = "{{date|date:\"YYYY-MM-DD\"}}"
      type = "date"
    },
    new Property {
      name = "modified"
      value = "{{date|date:\"YYYY-MM-DD\"}}"
      type = "date"
    },
    new Property {
      name = "title"
      value = ""
      type = "text"
    },
    new Property {
      name = "url"
      value = "{{url}}"
      type = "text"
    },
    new Property {
      name = "author"
      value = "{{author}}"
      type = "multitext"
    },
    new Property {
      name = "image"
      value = "{{selector:img[alt=\"画像\"]?src|first}}"
      type = "text"
    },
    new Property {
      name = "published"
      value = "{{published}}"
      type = "text"
    },
    new Property {
      name = "categories"
      value = #"[[clippings]]"#
      type = "multitext"
    },
    new Property {
      name = "tags"
      value = ""
      type = "multitext"
    },
  )

triggers = List()

noteNameFormat = "{{title}}"

path = "Clippings"
