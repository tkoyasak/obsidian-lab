amends "../WebClipper.pkl"

name = "zenn"

behavior = "create"

noteContentFormat =
  """
  <%*
    await tp.user.unique_note(tp)
  -%>

  {{content|replace:("/、/g":"，","/。/g":"．")}}

  """

properties =
  List(
    new Property {
      name = "id"
      value = ""
      type = "text"
    },
    new Property {
      name = "created"
      value = #"{{date|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "modified"
      value = #"{{date|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "title"
      value = "{{title}}"
      type = "text"
    },
    new Property {
      name = "source"
      value = "{{url}}"
      type = "text"
    },
    new Property {
      name = "published"
      value = #"{{published|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "authors"
      value = #"[\"{{selector:[class^=\"ProfileCard_displayName__\"]}}\"]"#
      type = "multitext"
    },
    new Property {
      name = "categories"
      value = #"[\"clippings\", \"posts\"]"#
      type = "multitext"
    },
    new Property {
      name = "genres"
      value =
        #"[\"{{selector:[class^=\"View_topics__\"]>a>[class^=\"View_topicName__\"]|lower}}\"]"#
      type = "multitext"
    },
    new Property {
      name = "tags"
      value = #"{{selector:[class^=\"View_topics__\"]>a>[class^=\"TopicList_name__\"]|lower}}"#
      type = "multitext"
    },
  )

triggers = List("https://zenn.dev/")

noteNameFormat = "{{title}}"

path = "11-clippings"
