amends "../WebClipper.pkl"

name = "hatena"

behavior = "create"

noteContentFormat =
  #"""
  <%*
    await tp.user.unique_note(tp)
  -%>

  {{content|replace:"/\[([^\]]+)\]\(https:\/\/d\.hatena\.ne\.jp\/keyword\/[^\)]*\)/g":"$1"|replace:("/、/g":"，","/。/g":"．")}}

  """#

properties =
  List(
    new Property {
      name = "id"
      value = ""
      type = "text"
    },
    new Property {
      name = "created"
      value = #"{{date|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "modified"
      value = #"{{date|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "title"
      value = "{{title}}"
      type = "text"
    },
    new Property {
      name = "source"
      value = "{{url}}"
      type = "text"
    },
    new Property {
      name = "published"
      value = #"{{published|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "authors"
      value = #"[\"{{author}}\"]"#
      type = "multitext"
    },
    new Property {
      name = "categories"
      value = #"[\"clippings\"]"#
      type = "multitext"
    },
    new Property {
      name = "genres"
      value = ""
      type = "multitext"
    },
    new Property {
      name = "tags"
      value = ""
      type = "multitext"
    },
  )

triggers = List("https://blog-dry.com/")

noteNameFormat = "{{title}}"

path = "11-clippings"
