amends "../WebClipper.pkl"

name = "amazon"

behavior = "create"

noteContentFormat =
  """
  <%*
    await tp.user.unique_note(tp)
  -%>

  {{selector:#landingImage?src|image}}

  {{selector:#bookDescription_feature_div>.a-expander-collapsed-height>.a-expander-content>span|replace:("/、/g":"，","/。/g":"．")}}

  """

properties =
  List(
    new Property {
      name = "id"
      value = ""
      type = "text"
    },
    new Property {
      name = "created"
      value = #"{{date|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "modified"
      value = #"{{date|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "title"
      value = #"\"『{{selector:#productTitle}}』\""#
      type = "text"
    },
    new Property {
      name = "isbn13"
      value = "{{selector:#rpi-attribute-book_details-isbn13>.rpi-attribute-value>span}}"
      type = "text"
    },
    new Property {
      name = "published"
      value =
        #"{{selector:#rpi-attribute-book_details-publication_date>.rpi-attribute-value>span|date:\"YYYY-MM-DD\"}}"#
      type = "date"
    },
    new Property {
      name = "urls"
      value = #"[\"ndl\", \"{{selector:link[rel=\"canonical\"]?href}}\"]"#
      type = "multitext"
    },
    new Property {
      name = "authors"
      value = "{{selector:#bylineInfo>.author>a}}"
      type = "multitext"
    },
    new Property {
      name = "categories"
      value = #"[\"references\", \"books\"]"#
      type = "multitext"
    },
    new Property {
      name = "genres"
      value = "{{selector:#wayfinding-breadcrumbs_feature_div .a-list-item>a|slice:1}}"
      type = "multitext"
    },
    new Property {
      name = "tags"
      value = ""
      type = "multitext"
    },
  )

triggers = List("https://www.amazon.co.jp/")

noteNameFormat = "『{{selector:#productTitle}}』"

path = "10-references"
